# Copy to .env and fill in

# Supabase project — find these under Project Settings > API in the
# Supabase dashboard. Use the service_role key (click "reveal"), not the
# publishable/anon key — the backend needs to bypass Row Level Security to
# write bookings. NEVER expose this key to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

PORT=4000

# Fare model: flat hourly rate per the brief
HOURLY_RATE=50

# Anthropic API key for conversational booking.
# Get one at https://console.anthropic.com/ . NEVER expose this to the frontend.
# If left blank, the AI booking endpoint returns a clear "not configured" error
# and the quick-form flow still works fully.
ANTHROPIC_API_KEY=
