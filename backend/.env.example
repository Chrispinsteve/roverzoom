# Copy to .env and fill in

DATABASE_URL=postgres://roverzoom:roverzoom@localhost:5432/roverzoom
PORT=4000

# Fare model: flat hourly rate per the brief
HOURLY_RATE=50

# Anthropic API key for conversational booking.
# Get one at https://console.anthropic.com/ . NEVER expose this to the frontend.
# If left blank, the AI booking endpoint returns a clear "not configured" error
# and the quick-form flow still works fully.
ANTHROPIC_API_KEY=
