# Copy to .env and fill in

# Backend API base URL. Leave blank in dev — Vite proxies /api to the
# backend (see vite.config.js). Set to your deployed API URL in production
# only if the frontend is hosted separately from the backend.
VITE_API_URL=

# Supabase project — same project as backend/.env, but these are the
# PUBLIC anon/publishable key + URL (find under Project Settings > API).
# Safe to expose to the browser: access is constrained by RLS policies, not
# by keeping this secret. NEVER put SUPABASE_SERVICE_ROLE_KEY here — that
# one must only ever live in backend/.env.
VITE_SUPABASE_URL=https://mktoysczpgibaokqivwv.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1rdG95c2N6cGdpYmFva3Fpdnd2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM2MTg3MTUsImV4cCI6MjA5OTE5NDcxNX0.iEgTSPhsR0eVO85nbiYzM4ezfQniT3GPjvXkePUzggI

# Driver mode stub identity (no driver auth yet). Set this to the `id`
# returned by backend/db/seed-dev-driver.sql after running it once.
VITE_DEV_DRIVER_ID=3fb305cf-4714-4f1c-b88d-ce1b4676db19
